# Copy this file to ~/.config/tmux/status.env and set mode 600.
# Weather data requires your private QWeather API Host and API KEY.

# Optional human-readable label shown in the status bar. Leave blank to let
# QWeather resolve a localized name from the automatically detected coordinates.
STATUS_LOCATION_LABEL=""

# Filled automatically on first install when left blank. Decimal degrees:
# east and north are positive. Air quality and 7Timer astronomy require both.
STATUS_LONGITUDE=""
STATUS_LATITUDE=""

# Optional QWeather city ID. If empty, the coordinates above are used.
QWEATHER_LOCATION_ID=""
# Copy your private API Host from https://console.qweather.com/setting
QWEATHER_API_HOST=""
QWEATHER_API_KEY=""

# NASA DEMO_KEY works at low volume; use a personal key for regular use.
NASA_API_KEY="DEMO_KEY"
NASA_LOOKBACK_DAYS="3"
