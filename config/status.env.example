# Copy this file to ~/.config/tmux/status.env and set mode 600.
# The only credential required for weather data is QWEATHER_API_KEY.

# Human-readable label shown in the status bar.
STATUS_LOCATION_LABEL="Your City"

# Required for air quality, 7Timer astronomy, and automatic city lookup.
# Decimal degrees: east and north are positive.
STATUS_LONGITUDE=""
STATUS_LATITUDE=""

# Optional QWeather city ID. If empty, the coordinates above are used.
QWEATHER_LOCATION_ID=""
QWEATHER_API_HOST="devapi.qweather.com"
QWEATHER_API_KEY=""

# NASA DEMO_KEY works at low volume; use a personal key for regular use.
NASA_API_KEY="DEMO_KEY"
NASA_LOOKBACK_DAYS="3"
